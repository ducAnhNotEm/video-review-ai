{
  "name": "video-review-ai-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "AI Video Agent and Editor",
  "workspaces": [
    "apps/desktop",
    "apps/backend",
    "apps/frontend",
    "shared"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=apps/backend",
    "dev:frontend": "npm run dev --workspace=apps/frontend",
    "dev:desktop": "npm run dev --workspace=apps/desktop",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:desktop\"",
    "build:shared": "npm run build --workspace=shared",
    "build:frontend": "npm run build --workspace=apps/frontend",
    "build:backend": "npm run build --workspace=apps/backend",
    "build:desktop": "npm run build --workspace=apps/desktop",
    "build": "npm run build:shared && npm run build:backend && npm run build:frontend && npm run build:desktop"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3"
  }
}
